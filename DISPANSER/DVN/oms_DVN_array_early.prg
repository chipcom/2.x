          // 70.3.156 ЗС дисп-ии женщин (60 лет), 1 этап
          // 70.3.194 ЗС дисп-ии женщин (60 лет) без цитологического исследования, 1 этап
        Elseif _vozrast == 63
          lshifr := '70.3.160'
