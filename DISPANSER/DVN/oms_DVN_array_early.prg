        Elseif _vozrast == 66
          lshifr := '70.3.140'
          // 70.3.140 ЗС дисп-ии женщин (66 лет), 1 этап
        Elseif _vozrast == 69
          lshifr := '70.3.142'
          // 70.3.142 ЗС дисп-ии женщин (69 лет), 1 этап
        Elseif _vozrast == 72
          lshifr := '70.3.146'
          // 70.3.146 ЗС дисп-ии женщин (72 лет), 1 этап
        Elseif eq_any( _vozrast, 75, 78, 81, 84 )
          lshifr := '70.3.168'
