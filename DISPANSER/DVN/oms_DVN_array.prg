// 24.03.26
function dvn_arr_usl_new( dateSl, mobil, etap, gender, age ) 

  local aDvn, i, fl

  Default dateSl To 0d20210101
  default mobil to 0

  // 1- наименование услуги
  // 2- шифр услуги
  // 3- этап (1, 2, 3, 4, 5)
  // 4- (0-диагностика, 1-осмотр врача)
  // 5-
  // 6- возрост (мужчины)
  // 7- возрост (женщины)
  // 8- мужчины (0-нет, 1-да) - похоже вывод на экран 
  // 9- женщины (0-нет, 1-да) - похоже вывод на экран
  // 10- V002 - Классификатор профилей оказанной медицинской помощи
  // 11- V004 - Классификатор медицинских специальностей

  If dateSl >= 0d20260101
//    aDvn := arr_usl_2026( mobil )
    aDvn := arr_usl_2026_new( mobil )
  elseIf ( dateSl >= 0d20210101 ) .and. ( dateSl < 0d20260101 )
    aDvn := arr_usl_2021( dateSl, mobil, age )
  Elseif ( dateSl >= 0d20190101 ) .and. ( dateSl < 0d20210101 )
    aDvn := arr_usl_2019( mobil )
  else
    aDvn := arr_usl_2018( mobil )
  Endif

  for i := Len( aDvn ) to 1 step -1
    fl := .f.
    If ValType( aDvn[ i, 3 ] ) == 'N'
      fl := ( aDvn[ i, 3 ] == etap )
    Else
      fl := AScan( aDvn[ i, 3 ], etap ) > 0
    Endif

    If fl
      if ValType( aDvn[ i, 6 ] ) == 'N' .and. aDvn[ i, 6 ] == 1 .and. gender == 'М'
        fl := .t.
      elseif ValType( aDvn[ i, 7 ] ) == 'N' .and. aDvn[ i, 7 ] == 1 .and. gender == 'Ж'
        fl := .t.
      elseif ValType( aDvn[ i, 6 ] ) == 'A' .and. gender == 'М'
        fl := AScan( aDvn[ i, 6 ], age ) > 0
      elseif ValType( aDvn[ i, 7 ] ) == 'A' .and. gender == 'Ж'
        fl := AScan( aDvn[ i, 7 ], age ) > 0
      else
        fl := .f.
      endif
    endif


    if ! fl
      hb_ADel( aDvn, i, .t. )
    endif
  next

  return aDvn

