  local arr_dvn_usl

  Default dateSl To 0d20210101
  default mobil to 0
  arr_dvn_usl := {}
  If dateSl >= 0d20260101
    arr_dvn_usl := arr_usl_2026( mobil )
  elseIf ( dateSl >= 0d20210101 ) .and. ( dateSl < 0d20260101 )
    arr_dvn_usl := arr_usl_2021( dateSl, mobil, mdvozrast )
  Elseif ( dateSl >= 0d20190101 ) .and. ( dateSl < 0d20210101 )
    arr_dvn_usl := arr_usl_2019( mobil )
  else
    arr_dvn_usl := arr_usl_2018( mobil )
  Endif

  return arr_dvn_usl

